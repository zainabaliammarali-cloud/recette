
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Recipe - recette</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <header>
      <h1>recette</h1>
    </header>

    <%- include('../partials/navbar') %>

    <main>
      <section>
        <h1>Edit Recipe</h1>
        <form action="/recipe/<%=recipe._id%>/recipeDetails/edit?_method=PUT" method="post">
            <label for="title">Title:</label>
            <input value="<%= recipe.title %>" name="title" id="title" type="text" required>
            <label for="description">Description:</label>
            <input value="<%= recipe.description %>" name="description" id="description" type="text" required>
            <label for="cuisine">Cuisine:</label>
            <input value="<%= recipe.cuisine %>" name="cuisine" id="cuisine" type="text" required>
            <label for="difficulty">Difficulty:</label>
            <input value="<%= recipe.difficulty %>" name="difficulty" id="difficulty" type="text" required>
            <label for="prepTime">Prep Time:</label>
            <input value="<%= recipe.prepTime %>" name="prepTime" id="prepTime" type="number" required>
            <label for="cookTime">Cook Time:</label>
            <input value="<%= recipe.cookTime %>" name="cookTime" id="cookTime" type="number" required>
            <label for="servings">Servings:</label>
            <input value="<%= recipe.servings %>" name="servings" id="servings" type="number" required>
            <label for="imageUrl">Image URL:</label>
            <input value="<%= recipe.imageUrl %>" name="imageUrl" id="imageUrl" type="text" required>
            <button type="submit">Edit Recipe</button>
        </form>
      </section>
    </main>

    <footer>
      <p>&copy; 2026 recette. All rights reserved.</p>
    </footer>
</body>
</html>
