
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Recipes - recette</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <header>
      <h1>recette</h1>
    </header>

    <%- include('../partials/navbar') %>

    <main>
      <section>
        <h1>All Recipes</h1>
        <% for(let oneRecipe of recipes){ %>
            <div class="recipe-card">
                <p><%= oneRecipe.title %></p>
                <a href="/recipe/<%=oneRecipe._id%>/recipeDetails">Show Recipe Details</a>
            </div>
        <% } %>
      </section>

      <section class="daily-notes">
        <h3>My Cooking Notes</h3>
        <p>Add your daily notes about cooking recipes here:</p>
        <textarea class="notes-input" placeholder="Write your notes... (tips, modifications, experiences)"></textarea>
        <button type="button">Save Note</button>
      </section>
    </main>

    <footer>
      <p>&copy; 2026 recette. All rights reserved.</p>
    </footer>
</body>
</html>